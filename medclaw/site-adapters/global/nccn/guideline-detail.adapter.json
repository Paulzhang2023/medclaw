{
  "schemaVersion": 1,
  "id": "guideline.nccn.detail.v1",
  "site": "guideline",
  "scope": "global",
  "owner": "MedClaw",
  "priority": 85,
  "tags": ["guideline", "nccn"],
  "pages": [
    {
      "pageType": "guideline-detail",
      "match": {
        "hosts": ["nccn.org"],
        "pathPrefixes": ["/guidelines/", "/patient-guidelines/"]
      },
      "ready": {
        "waitForSelector": "h1, main h1",
        "snapshotMode": "efficient"
      },
      "extraction": {
        "kind": "detail",
        "fields": [
          {
            "key": "Source",
            "selector": "meta[property='og:site_name']",
            "value": "text",
            "attr": "content"
          },
          {
            "key": "Date",
            "selector": "main, article, body",
            "value": "text",
            "transforms": ["extractYear"]
          },
          {
            "key": "Section",
            "selector": "h1, main h1",
            "value": "text",
            "required": true,
            "transforms": ["trim", "collapseWhitespace"]
          },
          {
            "key": "Recommendation summary",
            "selector": "main p, article p, .rich-text p",
            "value": "text",
            "transforms": ["trim", "collapseWhitespace"]
          },
          {
            "key": "Strength/grade",
            "selector": "main, article, body",
            "value": "text",
            "transforms": ["trim", "collapseWhitespace"]
          }
        ],
        "outputColumns": ["Source", "Date", "Section", "Recommendation summary", "Strength/grade"]
      },
      "notes": [
        "NCCN pages may have access restrictions on some professional guideline routes.",
        "Use fallback browser navigation when the page requires authentication."
      ]
    }
  ]
}

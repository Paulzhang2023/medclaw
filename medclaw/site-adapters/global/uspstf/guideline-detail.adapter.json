{
  "schemaVersion": 1,
  "id": "guideline.uspstf.detail.v1",
  "site": "guideline",
  "scope": "global",
  "owner": "MedClaw",
  "priority": 90,
  "tags": ["guideline", "uspstf"],
  "pages": [
    {
      "pageType": "guideline-detail",
      "match": {
        "hosts": ["uspreventiveservicestaskforce.org"],
        "pathPrefixes": ["/uspstf/recommendation/"]
      },
      "ready": {
        "waitForSelector": "h1, main h1",
        "snapshotMode": "efficient"
      },
      "extraction": {
        "kind": "detail",
        "fields": [
          {
            "key": "Source",
            "selector": "meta[property='og:site_name']",
            "value": "text",
            "attr": "content"
          },
          {
            "key": "Date",
            "selector": "main, article, body",
            "value": "text",
            "transforms": ["extractYear"]
          },
          {
            "key": "Section",
            "selector": "h1, main h1",
            "value": "text",
            "required": true,
            "transforms": ["trim", "collapseWhitespace"]
          },
          {
            "key": "Recommendation summary",
            "selector": "main p, article p",
            "value": "text",
            "transforms": ["trim", "collapseWhitespace"]
          },
          {
            "key": "Strength/grade",
            "selector": "main, article, body",
            "value": "text",
            "transforms": ["trim", "collapseWhitespace"]
          }
        ],
        "outputColumns": ["Source", "Date", "Section", "Recommendation summary", "Strength/grade"]
      },
      "notes": [
        "USPSTF recommendation statements often include a letter grade and summary near the top.",
        "Later refinement can target recommendation-grade badges directly."
      ]
    }
  ]
}

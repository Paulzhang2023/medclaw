{
  agents: {
    list: [
      {
        id: "medclaw",
        default: true,
        identity: {
          name: "MedClaw",
          theme: "clinical evidence copilot",
          emoji: "🩺",
        },
      },
    ],
    defaults: {
      workspace: "~/.medclaw/workspace",
      imageMaxDimensionPx: 960,
    },
  },

  gateway: {
    mode: "local",
  },

  tools: {
    profile: "coding",
  },

  browser: {
    snapshotDefaults: {
      mode: "efficient",
    },
  },

  skills: {
    allowBundled: [
      "med-pubmed-search",
      "med-clinicaltrials-search",
      "med-guideline-review",
      "med-deepevidence-entry",
      "med-seekevidence-entry",
      "capability-evolver-codex",
      "skill-creator",
      "skill-installer",
      "long-term-memory",
      "skill-intake-auditor",
      "pdf",
      "ai-data-analysis",
      "spreadsheet",
      "xlsx-manipulation",
      "screenshot",
      "pubmed-search",
      "medical-research-toolkit",
      "medical-specialty-briefs",
      "biomedical-search",
      "clinical-trial-protocol-skill",
      "clinicaltrials-database",
      "literature-review",
      "tooluniverse-precision-oncology",
      "tooluniverse-variant-analysis",
      "tooluniverse-gwas-drug-discovery",
      "statistical-analysis",
      "data-stats-analysis",
      "exploratory-data-analysis",
      "scientific-visualization",
      "data-transform",
      "scientific-writing",
      "scientific-brainstorming",
      "hypothesis-generation",
      "peer-review",
      "citation-management",
      "research-grants",
      "scientific-problem-selection",
      "nano-pdf",
      "summarize",
    ],
  },

  env: {
    vars: {
      MEDCLAW_SEEKEVIDENCE_URL: "https://seekevidence.medsci.cn",
      MEDCLAW_DEEPEVIDENCE_URL: "https://deepevid.medsci.cn",
      // Default cloud registry:
      // MEDCLAW_ADAPTER_REGISTRY_URL: "https://seekevidence.medon.com.cn/medclaw/",
      // MEDCLAW_ADAPTER_REGISTRY_TOKEN: "<set this in your environment>",
      // For local registry development, override with:
      // MEDCLAW_ADAPTER_REGISTRY_URL: "http://127.0.0.1:4318",
    },
  },
}
